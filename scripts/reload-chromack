#!/usr/bin/env bash
set -euo pipefail

CHROMACK_QT_PLATFORM="${CHROMACK_QT_PLATFORM:-wayland}"
CHROMACK_QT_SHELL_INTEGRATION="${CHROMACK_QT_SHELL_INTEGRATION:-layer-shell}"
CHROMACK_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(/usr/bin/id -u)}"
STATE_DIR="${CHROMACK_RUNTIME_DIR}/chromack"
STATE_FILE="${CHROMACK_STATE_FILE:-${STATE_DIR}/panel.state}"
PKILL_BIN="/usr/bin/pkill"
PGREP_BIN="/usr/bin/pgrep"
KILL_BIN="/usr/bin/kill"
SLEEP_BIN="/usr/bin/sleep"
NOHUP_BIN="/usr/bin/nohup"

usage() {
    printf 'Usage: %s [--dry-run]\n' "${0##*/}"
}

resolve_chromack_bin() {
    if [[ -n "${CHROMACK_BIN:-}" ]]; then
        printf '%s\n' "$CHROMACK_BIN"
        return
    fi

    local candidates=(
        "$HOME/builds/chromack/build-chromack/chromack"
        "$HOME/builds/chromack/build/chromack"
    )

    local path
    for path in "${candidates[@]}"; do
        if [[ -x "$path" ]]; then
            printf '%s\n' "$path"
            return
        fi
    done

    printf '%s\n' "${candidates[0]}"
}

collect_pids() {
    local chromack_bin="$1"

    {
        "$PGREP_BIN" -x chromack 2>/dev/null || true
        "$PGREP_BIN" -f -- "$chromack_bin" 2>/dev/null || true
    } | /usr/bin/awk 'NF { print $1 }' | /usr/bin/awk '!seen[$1]++'
}

write_state() {
    local state="$1"
    local tmp_file=""

    /usr/bin/mkdir -p "$STATE_DIR"
    tmp_file="$(/usr/bin/mktemp "${STATE_DIR}/.panel.state.XXXXXX")"
    printf '%s\n' "$state" > "$tmp_file"
    /usr/bin/mv "$tmp_file" "$STATE_FILE"
}

stop_chromack() {
    local chromack_bin="$1"
    local pids=()

    mapfile -t pids < <(collect_pids "$chromack_bin")
    [[ ${#pids[@]} -gt 0 ]] || return 0

    "$PKILL_BIN" -x chromack >/dev/null 2>&1 || true
    "$PKILL_BIN" -f -- "$chromack_bin" >/dev/null 2>&1 || true

    for _ in {1..20}; do
        mapfile -t pids < <(collect_pids "$chromack_bin")
        [[ ${#pids[@]} -eq 0 ]] && return 0
        "$SLEEP_BIN" 0.05
    done

    mapfile -t pids < <(collect_pids "$chromack_bin")
    if [[ ${#pids[@]} -gt 0 ]]; then
        "$KILL_BIN" -9 "${pids[@]}" >/dev/null 2>&1 || true
    fi

    for _ in {1..20}; do
        mapfile -t pids < <(collect_pids "$chromack_bin")
        [[ ${#pids[@]} -eq 0 ]] && return 0
        "$SLEEP_BIN" 0.05
    done

    return 1
}

start_chromack() {
    local chromack_bin="$1"

    QT_QPA_PLATFORM="$CHROMACK_QT_PLATFORM" \
        QT_WAYLAND_SHELL_INTEGRATION="$CHROMACK_QT_SHELL_INTEGRATION" \
        CHROMACK_START_OPEN=false \
        CHROMACK_STATE_FILE="$STATE_FILE" \
        XDG_RUNTIME_DIR="$CHROMACK_RUNTIME_DIR" \
        "$NOHUP_BIN" "$chromack_bin" >/dev/null 2>&1 &
}

wait_for_chromack() {
    local chromack_bin="$1"
    local pids=()

    for _ in {1..40}; do
        mapfile -t pids < <(collect_pids "$chromack_bin")
        if [[ ${#pids[@]} -gt 0 ]]; then
            return 0
        fi
        "$SLEEP_BIN" 0.05
    done

    return 1
}

main() {
    local dry_run=0
    local chromack_bin=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                dry_run=1
                ;;
            --help|-h)
                usage
                return 0
                ;;
            *)
                usage >&2
                return 2
                ;;
        esac
        shift
    done

    chromack_bin="$(resolve_chromack_bin)"

    if [[ "$dry_run" -eq 1 ]]; then
        printf 'binary=%s\n' "$chromack_bin"
        printf 'state=closed\n'
        return 0
    fi

    [[ -x "$chromack_bin" ]] || return 1

    stop_chromack "$chromack_bin"
    write_state "closed"
    start_chromack "$chromack_bin"
    wait_for_chromack "$chromack_bin"
}

main "$@"
